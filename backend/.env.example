# Async SQLAlchemy URL for MySQL (asyncmy driver)
# Create database first: CREATE DATABASE e2ee_messaging CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:3306/e2ee_messaging

# JSON list of allowed browser origins (Vite dev server, production URL, etc.)
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
